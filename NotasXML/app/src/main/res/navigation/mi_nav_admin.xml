<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mi_nav_admin"
    app:startDestination="@id/nav_usuarios">

    <fragment
        android:id="@+id/nav_usuarios"
        android:name="com.example.notasxml.PaginaUsuarioFragment"
        android:label="Gestión de Usuarios"
        tools:layout="@layout/fragment_usuario">
        <action
            android:id="@+id/action_nav_usuarios_to_nav_perfil"
            app:destination="@id/nav_perfil" />
    </fragment>

    <fragment
        android:id="@+id/nav_notas"
        android:name="com.example.notasxml.NotasAdminFragment"
        android:label="Notas"
        tools:layout="@layout/fragment_notas_admin" />

    <fragment
        android:id="@+id/nav_perfil"
        android:name="com.example.notasxml.PerfilFragment"
        android:label="Perfil"
        tools:layout="@layout/fragment_perfil" />

</navigation>